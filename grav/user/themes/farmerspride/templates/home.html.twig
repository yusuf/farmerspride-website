{% extends 'partials/base.twig' %}

{% set cfg = config.themes.farmerspride %}
{% set wp  = cfg.whatsapp|replace({'+': '', ' ': '', '-': ''}) %}
{% set h   = page.header %}

{% block content %}

{# ═══════════════════════════════════════════════════════════
   SECTION 1 — HERO
═══════════════════════════════════════════════════════════ #}
<section class="hero" aria-label="Hero">
  <img src="{{ url('theme://images/hero-bg.jpg') }}"
       alt=""
       class="hero-bg"
       loading="eager"
       onerror="this.style.display='none'">
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="container-site w-full">
      <h1 class="hero-headline text-center">{{ h.hero.headline }}</h1>
      <p class="hero-subheadline">{{ h.hero.subheadline }}</p>

      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
           class="btn btn-primary btn-lg btn-pill w-full sm:w-auto">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true" style="width:18px;height:18px;margin-right:8px;flex-shrink:0;">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
          </svg>
          {{ h.hero.cta_primary }}
        </a>
        <a href="{{ page.find('/products').url ?? '/products' }}"
           class="btn btn-secondary btn-lg btn-pill w-full sm:w-auto">
          {{ h.hero.cta_secondary }}
        </a>
      </div>
    </div>
  </div>

  {# Trust line pinned to bottom of hero #}
  <div class="hero-trust-bar">
    <span>{{ h.hero.trust_line }}</span>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 2 — TRUST STRIP
═══════════════════════════════════════════════════════════ #}
<div class="trust-strip" role="list" aria-label="Why customers trust us">
  <div class="trust-strip-inner">
    {% for item in h.trust_strip %}
    <div class="trust-strip-item" role="listitem">
      <svg class="trust-strip-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>{{ item.label }}</span>
    </div>
    {% if not loop.last %}
      <span class="trust-strip-divider" aria-hidden="true">|</span>
    {% endif %}
    {% endfor %}
  </div>
</div>

{# ═══════════════════════════════════════════════════════════
   SECTION 3 — PRODUCT CATEGORIES
═══════════════════════════════════════════════════════════ #}
{% set cs = h.categories_section %}
<section class="section" aria-labelledby="categories-heading">
  <div class="container-site">

    <div class="text-center mb-10">
      <h2 id="categories-heading" class="section-title-ruled">{{ cs.heading }}</h2>
      <p class="mt-3" style="color:#6B6B6B;font-size:0.9375rem;">{{ cs.intro }}</p>
    </div>

    {# All 7 cards — single grid; 5th item offset to col 2 on desktop to centre last 3 #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-6">
      {% for cat in cs.categories %}
      <div class="category-card{% if loop.index == 5 %} md:col-start-2{% endif %}">
        <div class="category-card-img-wrap">
          <img src="{{ url('theme://images/categories/' ~ cat.img) }}"
               alt="{{ cat.name }}"
               class="category-card-img"
               loading="lazy"
               onerror="this.parentElement.classList.add('img-missing'); this.style.display='none';">
        </div>
        <div class="category-card-content">
          <h3 class="category-card-title">{{ cat.name }}</h3>
          <p class="category-card-desc">{{ cat.desc }}</p>
          <a href="{{ page.find('/products').url ?? '/products' }}"
             class="btn btn-primary btn-sm category-card-btn">
            View Products
          </a>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 4 — WHY CHOOSE
═══════════════════════════════════════════════════════════ #}
{% set wc = h.why_choose %}
<section class="section-alt" aria-labelledby="why-heading" style="padding-top:3.5rem;padding-bottom:3.5rem;">
  <div class="container-site" style="max-width:52rem;">
    <div class="text-center mb-8">
      <h2 id="why-heading" class="section-title-ruled">{{ wc.heading }}</h2>
    </div>
    <ul style="list-style:none;padding:0;margin:0;">
      {% for point in wc.points %}
      <li class="why-choose-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" class="why-choose-icon">
          <path d="M5 13l4 4L19 7"/>
        </svg>
        <span>{{ point }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 5 — SERVICES SNAPSHOT
═══════════════════════════════════════════════════════════ #}
{% set ss = h.services_snapshot %}
<section class="section" aria-labelledby="services-heading">
  <div class="container-site">
    <div class="text-center mb-8">
      <span class="section-label">{{ ss.label }}</span>
      <h2 id="services-heading" class="section-title-ruled mt-1">{{ ss.heading }}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
      {% for svc in ss.services %}
      <div class="service-card">
        <h3 style="font-size:1rem;font-weight:700;color:#1A1A1A;margin-bottom:0.5rem;">{{ svc.title }}</h3>
        <p style="font-size:0.875rem;color:#3D3D3D;line-height:1.6;">{{ svc.desc }}</p>
      </div>
      {% endfor %}
    </div>
    <div class="text-center">
      <a href="{{ page.find('/services').url ?? '/services' }}" class="btn btn-outline-green">{{ ss.cta }}</a>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 6 — CTA BAND
═══════════════════════════════════════════════════════════ #}
{% set cta = h.cta_band %}
<section class="cta-band" aria-labelledby="cta-heading">
  <img src="{{ url('theme://images/cta-bg.jpg') }}"
       alt=""
       class="cta-band-bg"
       loading="lazy"
       onerror="this.style.display='none'">
  <div class="cta-band-content container-site">
    <h2 id="cta-heading">{{ cta.heading }}</h2>
    <p>{{ cta.body }}</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
      <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
         class="btn btn-outline btn-pill w-full sm:w-auto">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;flex-shrink:0;">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
        Call Now
      </a>
      <a href="https://wa.me/{{ wp }}"
         class="btn btn-whatsapp btn-pill w-full sm:w-auto"
         target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;flex-shrink:0;">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        WhatsApp Us
      </a>
      <a href="mailto:{{ cfg.email }}"
         class="btn btn-secondary btn-pill w-full sm:w-auto">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;flex-shrink:0;">
          <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Email Us
      </a>
    </div>
  </div>
</section>

{% endblock %}
