{% extends 'partials/base.twig' %}

{% set cfg = config.themes.farmerspride %}
{% set wp  = cfg.whatsapp|replace({'+': '', ' ': '', '-': ''}) %}
{% set h   = page.header %}

{# Pull categories from products page #}
{% set products_page = page.find('/products') %}
{% set categories = products_page ? products_page.header.categories : [] %}

{# Pull services from services page #}
{% set services_page = page.find('/services') %}
{% set services_list = services_page ? services_page.header.services : [] %}

{% block content %}
<style>
  .navbar {
    background-color: #ffffff;
    border-bottom: 1px solid rgba(15, 34, 15, 0.08);
    box-shadow: 0 4px 18px rgba(7, 26, 7, 0.08);
  }
  .navbar-link {
    color: #1f2a1f;
    border-bottom-color: transparent;
  }
  .navbar-link:hover {
    color: #2d6a2d;
    border-bottom-color: rgba(45, 106, 45, 0.45);
  }
  .navbar-link.active {
    color: #2d6a2d;
    border-bottom-color: #2d6a2d;
  }
  .navbar-contact-link {
    color: #1f2a1f;
  }
  .navbar-contact-link:hover {
    color: #2d6a2d;
  }
  .navbar-contact-divider {
    color: rgba(15, 34, 15, 0.3);
  }
  .navbar-hamburger {
    color: #1f2a1f;
  }
</style>

{# ═══════════════════════════════════════════════════════════
   SECTION 1 — HERO
═══════════════════════════════════════════════════════════ #}
{% set hero_img = url('theme://images/hero-bg.jpg') %}
{% set hero_media = h.hero.img ? page.media[h.hero.img] ?? null : null %}
{% if hero_media %}
  {% set hero_img = hero_media.url|default(hero_img) %}
{% else %}
  {% set hero_guess = null %}
  {% for name, media in page.media.images %}
    {% if hero_guess is null %}
      {% set lower = name|lower %}
      {% if 'hero' in lower or 'header' in lower or 'banner' in lower %}
        {% set hero_guess = media %}
      {% endif %}
    {% endif %}
  {% endfor %}
  {% if hero_guess is null and page.media.images|length %}
    {% set hero_guess = page.media.images|first %}
  {% endif %}
  {% if hero_guess %}
    {% set hero_img = hero_guess.url %}
  {% endif %}
{% endif %}
<section class="hero" aria-label="Hero">
  <img src="{{ hero_img }}"
       alt=""
       class="hero-bg"
       loading="eager"
       onerror="this.style.display='none'">
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="container-site w-full">
      <h1 class="hero-headline text-center">{{ h.hero.headline }}</h1>
      <p class="hero-subheadline text-center">{{ h.hero.subheadline }}</p>

      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
           class="btn btn-primary btn-lg btn-pill w-full sm:w-auto">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true" style="width:18px;height:18px;margin-right:8px;flex-shrink:0;">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
          </svg>
          {{ h.hero.cta_primary|default('Call Now') }}
        </a>
        <a href="{{ products_page.url ?? '/products' }}"
           class="btn btn-secondary btn-lg btn-pill w-full sm:w-auto">
          {{ h.hero.cta_secondary|default('Browse Products') }}
        </a>
      </div>
    </div>
  </div>

  <div class="hero-trust-bar">
    <span>{{ h.hero.trust_line }}</span>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 2 — TRUST STRIP
═══════════════════════════════════════════════════════════ #}
{% if h.trust_strip %}
<div class="trust-strip" role="list" aria-label="Why customers trust us">
  <div class="trust-strip-inner">
    {% for item in h.trust_strip %}
    <div class="trust-strip-item" role="listitem">
      <svg class="trust-strip-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>{{ item.label }}</span>
    </div>
    {% if not loop.last %}
      <span class="trust-strip-divider" aria-hidden="true">|</span>
    {% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}

{# ═══════════════════════════════════════════════════════════
   SECTION 3 — PRODUCT CATEGORIES (pulled from products page)
═══════════════════════════════════════════════════════════ #}
{% set cs = h.categories_section %}
<section class="section" aria-labelledby="categories-heading">
  <div class="container-site">

    <div class="text-center mb-10">
      <h2 id="categories-heading" class="section-title-ruled">{{ cs.heading }}</h2>
      <p class="mt-3" style="color:#6B6B6B;font-size:1rem;">{{ cs.intro }}</p>
    </div>

    {# Row 1 — first 4 cards #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-6">
      {% for cat in categories|slice(0, 4) %}
      {% set cat_slug = cat.name|lower|replace({' ': '-', '&': 'and', "'": '', '/': '-', '.': ''}) %}
      {% set cat_image_key = cat.image ?? cat.img %}
      {% set cat_image_media = cat_image_key and products_page ? products_page.media[cat_image_key]|default(null) : null %}
      {% set cat_img_url = cat_image_media ? cat_image_media.url : null %}
      {% if not cat_img_url and cat_image_key %}
        {% if '://' in cat_image_key %}
          {% set cat_img_url = cat_image_key %}
        {% else %}
          {% set cat_img_url = url('theme://images/categories/' ~ cat_image_key) %}
        {% endif %}
      {% endif %}
      {% if not cat_img_url %}
        {% set cat_img_url = url('theme://images/hero-bg.jpg') %}
      {% endif %}
      <div class="category-card">
        <div class="category-card-img-wrap">
          <img src="{{ cat_img_url }}"
               alt="{{ cat.name }}"
               class="category-card-img"
               loading="lazy"
               onerror="this.parentElement.classList.add('img-missing'); this.style.display='none';">
        </div>
        <div class="category-card-content">
          <h3 class="category-card-title">{{ cat.name }}</h3>
          <p class="category-card-desc">{{ cat.desc }}</p>
          <a href="{{ (products_page.url ?? '/products') }}#cat-{{ cat_slug }}"
             class="btn btn-primary btn-sm category-card-btn">
            {{ cs.card_cta|default('View Products') }}
          </a>
        </div>
      </div>
      {% endfor %}
    </div>

    {# Row 2 — last 3 cards, centred #}
    <div class="category-row2 mt-5 md:mt-6">
      {% for cat in categories|slice(4) %}
      {% set cat_slug = cat.name|lower|replace({' ': '-', '&': 'and', "'": '', '/': '-', '.': ''}) %}
      {% set cat_image_key = cat.image ?? cat.img %}
      {% set cat_image_media = cat_image_key and products_page ? products_page.media[cat_image_key]|default(null) : null %}
      {% set cat_img_url = cat_image_media ? cat_image_media.url : null %}
      {% if not cat_img_url and cat_image_key %}
        {% if '://' in cat_image_key %}
          {% set cat_img_url = cat_image_key %}
        {% else %}
          {% set cat_img_url = url('theme://images/categories/' ~ cat_image_key) %}
        {% endif %}
      {% endif %}
      {% if not cat_img_url %}
        {% set cat_img_url = url('theme://images/hero-bg.jpg') %}
      {% endif %}
      <div class="category-card category-row2-card">
        <div class="category-card-img-wrap">
          <img src="{{ cat_img_url }}"
               alt="{{ cat.name }}"
               class="category-card-img"
               loading="lazy"
               onerror="this.parentElement.classList.add('img-missing'); this.style.display='none';">
        </div>
        <div class="category-card-content">
          <h3 class="category-card-title">{{ cat.name }}</h3>
          <p class="category-card-desc">{{ cat.desc }}</p>
          <a href="{{ (products_page.url ?? '/products') }}#cat-{{ cat_slug }}"
             class="btn btn-primary btn-sm category-card-btn">
            {{ cs.card_cta|default('View Products') }}
          </a>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 4 — WHY AGROLINK
═══════════════════════════════════════════════════════════ #}
{% set why = h.why_choose %}
{% if why %}
<section class="section-alt why-agrolink-section" aria-labelledby="why-agrolink-heading">
  <div class="container-site">
    <div class="why-agrolink-head text-center">
      {% if why.label %}<span class="section-label">{{ why.label }}</span>{% endif %}
      <h2 id="why-agrolink-heading" class="section-title-ruled">{{ why.heading|default('Why AgroLink') }}</h2>
      {% if why.intro %}
      <p class="why-agrolink-intro">{{ why.intro }}</p>
      {% endif %}
    </div>

    {% set points = why.points ?? [] %}
    {% if points %}
    <ul class="why-point-list" role="list">
      {% for point in points %}
        {% set text = point.title ?? point.item %}
        {% set detail = point.body %}
        {% if text %}
        <li class="why-point-item">
          <span class="why-point-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </span>
          <div class="why-point-copy">
            <span class="why-point-title">{{ text }}</span>
            {% if detail %}
            <p>{{ detail }}</p>
            {% endif %}
          </div>
        </li>
        {% endif %}
      {% endfor %}
    </ul>
    {% endif %}
  </div>
</section>
{% endif %}

{% set svc = h.services_snapshot %}
<section class="section" aria-labelledby="homepage-services-link" style="padding-top:0;">
  <div class="container-site">
    <div class="services-cta-head text-center">
      {% if svc.label %}<span class="section-label">{{ svc.label }}</span>{% endif %}
      {% if svc.heading %}<h2 id="homepage-services-link" class="section-title-ruled">{{ svc.heading }}</h2>{% endif %}
    </div>
    <div class="text-center mt-6">
      <a href="{{ services_page.url ?? '/services' }}" class="btn btn-outline-green inline-flex justify-center">
        {{ svc.cta|default('View Services & Support') }}
      </a>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 6 — CTA BAND
═══════════════════════════════════════════════════════════ #}
{% set cta = h.cta_band %}
{% set cta_img = url('theme://images/cta-bg.jpg') %}
{% set cta_media = cta.img ? page.media[cta.img] ?? null : null %}
{% if cta_media %}
  {% set cta_img = cta_media.url|default(cta_img) %}
{% else %}
  {% set cta_guess = null %}
  {% for name, media in page.media.images %}
    {% if cta_guess is null %}
      {% set lower = name|lower %}
      {% if 'cta' in lower or 'footer' in lower or 'band' in lower %}
        {% set cta_guess = media %}
      {% endif %}
    {% endif %}
  {% endfor %}
  {% if cta_guess is null and page.media.images|length > 1 %}
    {% set cta_guess = (page.media.images|last) %}
  {% elseif cta_guess is null and page.media.images|length %}
    {% set cta_guess = page.media.images|first %}
  {% endif %}
  {% if cta_guess %}
    {% set cta_img = cta_guess.url %}
  {% endif %}
{% endif %}
<section class="cta-band" aria-labelledby="cta-heading">
  <img src="{{ cta_img }}"
       alt=""
       class="cta-band-bg"
       loading="lazy"
       onerror="this.style.display='none'">
  <div class="cta-band-content container-site">
    <h2 id="cta-heading">{{ cta.heading }}</h2>
    <p>{{ cta.body }}</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
      <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
         class="btn btn-outline btn-pill w-full sm:w-auto">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;flex-shrink:0;">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
        {{ cta.cta_call|default('Call Now') }}
      </a>
      <a href="https://wa.me/{{ wp }}"
         class="btn btn-whatsapp btn-pill w-full sm:w-auto"
         target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;flex-shrink:0;">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        {{ cta.cta_whatsapp|default('WhatsApp Us') }}
      </a>
      <a href="mailto:{{ cfg.email }}"
         class="btn btn-secondary btn-pill w-full sm:w-auto">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;flex-shrink:0;">
          <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        {{ cta.cta_email|default('Email Us') }}
      </a>
    </div>
  </div>
</section>

{% endblock %}
