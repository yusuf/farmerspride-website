{% extends 'partials/base.twig' %}

{% set cfg = config.themes.farmerspride %}
{% set h   = page.header %}

{% block content %}

{# ── Page hero ── #}
<section class="page-hero" aria-label="About page header">
  <img src="{{ url('theme://images/hero-about.jpg') }}"
       alt=""
       class="hero-bg"
       loading="eager"
       onerror="this.style.display='none'">
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="page-hero-content">
    <h1>{{ h.hero.heading }}</h1>
    <p>{{ h.hero.subheading }}</p>
  </div>
</section>

{# ── Introduction ── #}
<section class="section" style="padding-bottom:2.5rem;" aria-label="Introduction">
  <div class="container-site max-w-3xl text-center">
    <p class="text-lg text-body" style="line-height:1.7;">{{ h.intro }}</p>
  </div>
</section>

{# ── Two-column: Who we are / How we work ── #}
<section class="section-alt" aria-labelledby="about-two-col-heading" style="padding-top:3rem;">
  <div class="container-site">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">

      {# Who we are #}
      <div>
        <h2 id="about-two-col-heading" class="text-2xl font-bold text-green-700 mb-4">{{ h.who_we_are.heading }}</h2>
        {% for para in h.who_we_are.paragraphs %}
        <p class="text-body mb-4" style="line-height:1.7;max-width:52ch;">{{ para }}</p>
        {% endfor %}
      </div>

      {# How we work #}
      <div>
        <h2 class="text-2xl font-bold text-green-700 mb-3">{{ h.how_we_work.heading }}</h2>
        <p class="text-body mb-5" style="line-height:1.7;">{{ h.how_we_work.intro }}</p>
        <ul class="checklist space-y-3">
          {% for point in h.how_we_work.points %}
          <li class="flex items-start gap-3">
            <svg class="checklist-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 13l4 4L19 7"/>
            </svg>
            <span><strong class="font-semibold text-dark">{{ point.title }}</strong> — {{ point.desc }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>

    </div>
  </div>
</section>

{# ── Built on experience ── #}
{% set exp = h.experience %}
<section class="section" aria-labelledby="experience-heading">
  <div class="container-site">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start mb-10">
      <div>
        <h2 id="experience-heading" class="text-2xl md:text-3xl font-bold text-green-700 mb-4">{{ exp.heading }}</h2>
        {% for para in exp.paragraphs %}
        <p class="text-body mb-4" style="line-height:1.7;max-width:52ch;">{{ para }}</p>
        {% endfor %}
      </div>
      <div>
        <ul class="checklist space-y-3">
          {% for point in exp.trust_points %}
          <li class="flex items-start gap-3">
            <svg class="checklist-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-body">{{ point }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>

    {# Stat boxes — optional decorative elements #}
    {% if exp.stats %}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {% for stat in exp.stats %}
      <div class="stat-box">
        <div class="stat-value">{{ stat.value }}</div>
        <div class="stat-label">{{ stat.label }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

  </div>
</section>

{# ── Belief statement panel ── #}
{% set belief = h.belief %}
<section class="section" style="padding-top:0;" aria-labelledby="belief-heading">
  <div class="container-site">
    <div class="belief-panel">
      <span class="section-label mb-3 block" style="color:#E8F5E8;opacity:0.8;">{{ belief.label }}</span>
      <blockquote id="belief-heading">{{ belief.statement }}</blockquote>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="{{ page.find('/contact').url ?? '/contact' }}"
           class="btn btn-outline">
          {{ belief.cta_primary }}
        </a>
        <a href="{{ page.find('/products').url ?? '/products' }}"
           class="btn btn-secondary">
          {{ belief.cta_secondary }}
        </a>
      </div>
    </div>
  </div>
</section>

{% endblock %}
