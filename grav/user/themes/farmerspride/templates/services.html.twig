{% extends 'partials/base.twig' %}

{% set cfg = config.themes.farmerspride %}
{% set wp  = cfg.whatsapp|replace({'+': '', ' ': '', '-': ''}) %}
{% set h   = page.header %}

{% block content %}

{% set services_title = h.services_title|default('Support that goes beyond the sale') %}
{% set services_subtitle = h.services_subtitle|default('Every service points customers straight to a phone call or WhatsApp chat.') %}

<style>
  .page-hero--services { min-height: 360px; }
  @media (min-width: 768px) { .page-hero--services { min-height: 420px; } }
  @media (min-width: 1024px) { .page-hero--services { min-height: 480px; } }
  .page-hero--services .hero-overlay {
    background: linear-gradient(135deg, rgba(7,20,7,0.92) 0%, rgba(26,74,26,0.6) 60%, rgba(26,74,26,0.4) 100%);
  }
  .page-hero--services .page-hero-content h1 { color: #fff; }

  .svc-intro-band {
    background: #F7FBF7;
    border-bottom: 1px solid #E4EDE4;
    padding: 2.75rem 1rem;
    text-align: center;
  }
  .svc-intro-heading { font-size: 1.5rem; font-weight: 700; color: #1A4A1A; margin-bottom: 0.5rem; }
  .svc-intro-body { font-size: 1rem; line-height: 1.75; color: #4A5A4A; margin: 0; }

  .svc-section-head { text-align: center; margin-bottom: 2.75rem; }
  .svc-section-title {
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 800;
    color: #0F2810;
    margin-bottom: 0.5rem;
    position: relative;
    display: inline-block;
    padding-bottom: 0.625rem;
  }
  .svc-section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2.75rem;
    height: 3px;
    background: #2D6A2D;
    border-radius: 2px;
  }
  .svc-section-sub { font-size: 0.95rem; color: #5A6A5A; margin: 0.75rem auto 0; max-width: 40rem; }

  .svc-services-section { padding: 3.75rem 1rem 4.25rem; background: #ffffff; }
  .svc-services-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }

  .svc-service-card {
    display: flex;
    flex-direction: column;
    border-radius: 1rem;
    overflow: hidden;
    background: #0f1f12;
    box-shadow: 0 12px 45px rgba(10,31,10,0.25);
    flex: 1 1 100%;
    max-width: 360px;
  }
  @media (min-width: 640px) {
    .svc-service-card { flex: 0 1 calc(50% - 1.5rem); }
  }
  @media (min-width: 1024px) {
    .svc-service-card { flex: 0 1 calc(33.333% - 1.5rem); }
  }

  .svc-service-photo {
    position: relative;
    height: 190px;
    background-size: cover;
    background-position: center;
  }
  .svc-service-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,10,0.15) 0%, rgba(10,10,10,0.55) 100%);
  }
  .svc-service-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .svc-service-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    color: #ffffff;
    background: linear-gradient(180deg, rgba(10,20,10,0.95) 0%, rgba(10,20,10,0.8) 70%, rgba(10,20,10,0.92) 100%);
  }
  @media (min-width: 1024px) { .svc-service-content { padding: 2.25rem; } }
  .svc-service-number {
    align-self: flex-start;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.35);
  }
  .svc-service-content h3 { font-size: 1.38rem; margin: 0; color: #fff; }
  .svc-service-body { margin: 0; font-size: 0.97rem; line-height: 1.7; color: rgba(255,255,255,0.9); flex: 1; }
  .svc-service-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .svc-service-ctas .btn {
    box-shadow: 0 8px 24px rgba(0,0,0,0.35);
    border-radius: 999px;
    padding: 0.55rem 1.4rem;
  }
</style>

{# ── Page hero ── #}
{% set hero_media = h.hero.img and page.media[h.hero.img] ? page.media[h.hero.img] : (page.media.images|length ? (page.media.images|first) : null) %}
{% set hero_img = hero_media ? hero_media.url : url('theme://images/hero-services.jpg') %}
<section class="page-hero page-hero--services" aria-label="Services page header">
  <img src="{{ hero_img }}"
       alt=""
       class="hero-bg"
       loading="eager"
       onerror="this.style.display='none'">
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="page-hero-content">
    <h1>{{ h.hero.heading }}</h1>
    <p>{{ h.hero.subheading }}</p>
  </div>
</section>

{# ── Introduction ── #}
{% if h.intro_heading or h.intro %}
<section class="svc-intro-band" aria-label="Services introduction">
  <div class="container-site" style="max-width:44rem;text-align:center;">
    {% if h.intro_heading %}
    <h2 class="svc-intro-heading">{{ h.intro_heading }}</h2>
    {% endif %}
    {% if h.intro %}
    <p class="svc-intro-body">{{ h.intro }}</p>
    {% endif %}
  </div>
</section>
{% endif %}

{# ── Service tiles ── #}
<section class="svc-services-section" aria-labelledby="services-list-heading">
  <div class="container-site">
    <div class="svc-section-head">
      <h2 id="services-list-heading" class="svc-section-title">{{ services_title }}</h2>
      {% if services_subtitle %}
      <p class="svc-section-sub">{{ services_subtitle }}</p>
      {% endif %}
    </div>

    <div class="svc-services-grid">
      {% for svc in h.services %}
        {% set svc_media = svc.img and page.media[svc.img] ? page.media[svc.img] : null %}
        {% set svc_img = svc_media ? svc_media.url : url('theme://images/hero-services.jpg') %}
        <article class="svc-service-card">
          <div class="svc-service-photo">
            <img src="{{ svc_img }}" alt="{{ svc.title }} service illustration" loading="lazy">
          </div>
          <div class="svc-service-content">
            <span class="svc-service-number">{{ loop.index < 10 ? '0' ~ loop.index : loop.index }}</span>
            <h3>{{ svc.title }}</h3>
            <p class="svc-service-body">{{ svc.body }}</p>
            <div class="svc-service-ctas">
              <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}" class="btn btn-primary btn-sm">Call Now</a>
              <a href="https://wa.me/{{ wp }}" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm">WhatsApp Us</a>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{# ── Contact prompt CTA band ── #}
{% set cp = h.contact_prompt %}
{% set cp_media = cp.img and page.media[cp.img] ? page.media[cp.img] : (page.media.images|length ? (page.media.images|last) : null) %}
{% set cta_img = cp_media ? cp_media.url : url('theme://images/cta-bg.jpg') %}
<section class="cta-band" aria-labelledby="services-cta-heading">
  <img src="{{ cta_img }}"
       alt=""
       class="cta-band-bg"
       loading="lazy"
       onerror="this.style.display='none'">
  <div class="cta-band-content container-site">
    <h2 id="services-cta-heading">{{ cp.heading }}</h2>
    <p class="max-w-xl mx-auto">{{ cp.body }}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
         class="btn btn-outline">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
        {{ cp.cta_primary|default('Call Us Now') }}
      </a>
      <a href="https://wa.me/{{ wp }}"
         class="btn btn-whatsapp"
         target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        {{ cp.cta_secondary|default('WhatsApp / Viber') }}
      </a>
      <a href="mailto:{{ cfg.email }}"
         class="btn btn-outline">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;">
          <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        {{ cp.cta_tertiary|default('Email Inquiry') }}
      </a>
    </div>
  </div>
</section>

{% endblock %}
