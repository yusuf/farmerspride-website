{% extends 'partials/base.twig' %}

{% set cfg = config.themes.farmerspride %}
{% set wp  = cfg.whatsapp|replace({'+': '', ' ': '', '-': ''}) %}
{% set h   = page.header %}

{% block content %}

{# ── Page hero ── #}
<section class="page-hero" aria-label="Contact page header">
  <img src="{{ url('theme://images/hero-contact.jpg') }}"
       alt=""
       class="hero-bg"
       loading="eager"
       onerror="this.style.display='none'">
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="page-hero-content">
    <h1>{{ h.hero.heading }}</h1>
    <p>{{ h.hero.subheading }}</p>
  </div>
</section>

{# ── Main contact section ── #}
<section class="section" aria-labelledby="contact-main-heading">
  <div class="container-site">

    <p class="text-body text-center mb-10 text-lg" style="line-height:1.7;">{{ h.intro }}</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

      {# ── Left column: contact blocks ── #}
      <div>
        <h2 id="contact-main-heading" class="text-2xl font-bold text-green-700 mb-6">Get in touch</h2>

        <div class="space-y-4">

          {# Phone block #}
          {% set phone_channel = null %}
          {% for ch in h.channels %}{% if ch.type == 'phone' %}{% set phone_channel = ch %}{% endif %}{% endfor %}
          {% if phone_channel %}
          <div class="contact-block">
            <div class="contact-block-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   style="width:20px;height:20px;">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold text-dark mb-0.5">{{ phone_channel.heading }}</h3>
              <p class="text-green-700 font-semibold text-lg mb-1">{{ cfg.phone }}</p>
              <p class="text-sm text-muted mb-3" style="line-height:1.5;">{{ phone_channel.desc }}</p>
              <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
                 class="btn btn-primary btn-sm">
                {{ phone_channel.cta }}
              </a>
            </div>
          </div>
          {% endif %}

          {# WhatsApp block #}
          {% set wa_channel = null %}
          {% for ch in h.channels %}{% if ch.type == 'whatsapp' %}{% set wa_channel = ch %}{% endif %}{% endfor %}
          {% if wa_channel %}
          <div class="contact-block">
            <div class="contact-block-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                   style="width:20px;height:20px;">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold text-dark mb-0.5">{{ wa_channel.heading }}</h3>
              <p class="text-green-700 font-semibold text-lg mb-1">{{ cfg.whatsapp }}</p>
              <p class="text-sm text-muted mb-3" style="line-height:1.5;">{{ wa_channel.desc }}</p>
              <a href="https://wa.me/{{ wp }}"
                 class="btn btn-secondary btn-sm"
                 target="_blank"
                 rel="noopener noreferrer">
                {{ wa_channel.cta }}
              </a>
            </div>
          </div>
          {% endif %}

          {# Email block #}
          {% set email_channel = null %}
          {% for ch in h.channels %}{% if ch.type == 'email' %}{% set email_channel = ch %}{% endif %}{% endfor %}
          {% if email_channel %}
          <div class="contact-block">
            <div class="contact-block-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   style="width:20px;height:20px;">
                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold text-dark mb-0.5">{{ email_channel.heading }}</h3>
              <p class="text-green-700 font-semibold mb-1 break-all">{{ cfg.email }}</p>
              <p class="text-sm text-muted mb-3" style="line-height:1.5;">{{ email_channel.desc }}</p>
              <a href="mailto:{{ cfg.email }}"
                 class="btn btn-secondary btn-sm">
                {{ email_channel.cta }}
              </a>
            </div>
          </div>
          {% endif %}

        </div>

        {# Address + hours #}
        <div class="mt-8 space-y-3">
          <div class="flex items-start gap-3 text-body">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true" style="width:18px;height:18px;flex-shrink:0;margin-top:2px;color:#2D6A2D;">
              <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div>
              <span class="font-semibold text-dark block text-sm mb-0.5">Find us</span>
              {{ cfg.address }}
            </div>
          </div>
          <div class="flex items-start gap-3 text-body">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true" style="width:18px;height:18px;flex-shrink:0;margin-top:2px;color:#2D6A2D;">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            <div>
              <span class="font-semibold text-dark block text-sm mb-0.5">Business hours</span>
              {{ cfg.business_hours }}
            </div>
          </div>
        </div>

      </div>

      {# ── Right column: contact form ── #}
      <div>
        <h2 class="text-2xl font-bold text-green-700 mb-2">{{ h.form.heading }}</h2>
        <p class="text-muted text-sm mb-6">{{ h.form.subheading }}</p>

        <form method="post" action="{{ page.url }}" novalidate>
          <input type="hidden" name="form-name" value="contact">

          <div class="form-group">
            <label class="form-label" for="contact-name">Name <span class="text-red-500" aria-hidden="true">*</span></label>
            <input class="form-input"
                   type="text"
                   id="contact-name"
                   name="name"
                   placeholder="Your name"
                   required
                   autocomplete="name">
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-phone">Phone Number</label>
            <input class="form-input"
                   type="tel"
                   id="contact-phone"
                   name="phone"
                   placeholder="+960 ..."
                   autocomplete="tel">
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-email">Email Address</label>
            <input class="form-input"
                   type="email"
                   id="contact-email"
                   name="email"
                   placeholder="you@example.com"
                   autocomplete="email">
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-message">Message <span class="text-red-500" aria-hidden="true">*</span></label>
            <textarea class="form-input"
                      id="contact-message"
                      name="message"
                      rows="5"
                      placeholder="Tell us what you need..."
                      required></textarea>
          </div>

          <button type="submit" class="btn btn-primary w-full justify-center">
            {{ h.form.submit }}
          </button>
        </form>

        <p class="text-sm text-muted mt-4 text-center">
          Or call us directly at
          <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
             class="font-semibold text-green-700">{{ cfg.phone }}</a>
          for a faster response.
        </p>
      </div>

    </div>
  </div>
</section>

{# ── Bottom CTA band ── #}
{% set cta = h.cta_band %}
<section class="cta-band" aria-labelledby="contact-cta-heading">
  <div class="cta-band-content container-site">
    <h2 id="contact-cta-heading">{{ cta.heading }}</h2>
    <p>{{ cta.body }}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
         class="btn btn-outline">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
        Call Now
      </a>
      <a href="https://wa.me/{{ wp }}"
         class="btn btn-whatsapp"
         target="_blank"
         rel="noopener noreferrer">
        WhatsApp Us
      </a>
    </div>
  </div>
</section>

{% endblock %}
