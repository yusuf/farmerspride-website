{% set cfg = config.themes.farmerspride %}
{% set wp = cfg.whatsapp|replace({'+': '', ' ': '', '-': ''}) %}

<header class="site-header" role="banner">
<nav class="navbar" role="navigation" aria-label="Main navigation">
  <div class="navbar-inner">

    {# ── Logo ── #}
    <div class="navbar-logo">
      <a href="{{ base_url == '' ? '/' : base_url }}" aria-label="Farmer's Pride by AgroLink — home">
        <img src="{{ url('theme://images/logo-navbar.png') }}"
             alt="Farmer's Pride by AgroLink"
             loading="eager"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
        <span style="display:none" class="navbar-logo-fallback">
          Farmer's Pride <span>by AgroLink</span>
        </span>
      </a>
    </div>

    {# ── Desktop nav links ── #}
    <div class="navbar-nav" aria-label="Site pages">
      <a href="{{ base_url == '' ? '/' : base_url }}"
         class="navbar-link{% if page.home %} active{% endif %}">Home</a>
      {% for p in pages.children %}
        {% if p.visible %}
          <a href="{{ p.url }}"
             class="navbar-link{% if page.url == p.url %} active{% endif %}">
            {{ p.title }}
          </a>
        {% endif %}
      {% endfor %}
    </div>

    {# ── Right: contact links + Call Now pill (desktop) + hamburger (mobile) ── #}
    <div class="navbar-actions">

      {# Desktop contact links #}
      <div class="navbar-contact-links hidden lg:flex items-center gap-5">
        <a href="https://wa.me/{{ wp }}"
           class="navbar-contact-link"
           target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
               aria-hidden="true" style="width:14px;height:14px;flex-shrink:0;">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          WhatsApp Us
        </a>
        <span class="navbar-contact-divider" aria-hidden="true">|</span>
        <a href="mailto:{{ cfg.email }}" class="navbar-contact-link">Email Us</a>
        <span class="navbar-contact-divider" aria-hidden="true">|</span>
      </div>

      <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
         class="navbar-call-btn hidden md:inline-flex"
         aria-label="Call us at {{ cfg.phone }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:14px;height:14px;flex-shrink:0;">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
        Call Now: {{ cfg.phone }}
      </a>

      <button id="menu-toggle"
              class="navbar-hamburger md:hidden"
              aria-controls="mobile-menu"
              aria-expanded="false"
              aria-label="Toggle navigation menu">
        <span id="icon-menu-open" style="display:block">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true" style="width:22px;height:22px;">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </span>
        <span id="icon-menu-close" style="display:none">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
               aria-hidden="true" style="width:22px;height:22px;">
            <path d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </span>
      </button>
    </div>

  </div>

  {# ── Mobile menu ── #}
  <div id="mobile-menu" class="mobile-menu" role="menu">
    <a href="{{ base_url == '' ? '/' : base_url }}"
       class="mobile-menu-link{% if page.home %} active{% endif %}" role="menuitem">Home</a>
    {% for p in pages.children %}
      {% if p.visible %}
        <a href="{{ p.url }}"
           class="mobile-menu-link{% if page.url == p.url %} active{% endif %}"
           role="menuitem">{{ p.title }}</a>
      {% endif %}
    {% endfor %}
    <div class="mobile-menu-actions">
      <a href="tel:{{ cfg.phone|replace({' ': '', '-': ''}) }}"
         class="btn btn-primary w-full justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true" style="width:16px;height:16px;margin-right:8px;">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
        </svg>
        Call Now
      </a>
      <a href="https://wa.me/{{ wp }}"
         class="btn btn-whatsapp w-full justify-center"
         target="_blank" rel="noopener noreferrer">
        WhatsApp Us
      </a>
    </div>
  </div>
</nav>
</header>
